# This include the list of dependencies and packege

# basic build tools
BASIC_PKG=(
	gcc
	gdb
	make
	cmake
	g++
	python3
	python3-pip
	nodejs
	npm
)

# libraries
LIB_PKG=(
	# json library
	libjson-c-dev
	cjson
	c-json
	libjson-c
	libjsoncpp-dev
	# libcurl
	libcurl4-openssl-dev
	curl
	# ncurses
	libncurses5-dev
	ncurses-dev
)

# basic tools
TOOLS_PKG=(
	git
	vim
	tmux
	htop
	neofetch
	wget
	zip
	unzip
	fzf
	trash-cli	
	valgrind
	strace
	sudo
	pandoc-cli
)

# man pages
MAN_PKG=(
	man-db
	man-pages
	tldr
)

# network tools
NET_PKG=(
	net-tools
	iputils-ping
	nmap
	openssh-server
	openssh-client
)

# GUI tools
GUI_PKG=(
	wireshark
	wireshark-qt
	wireshark-cli
	visual-studio-code
)

# Latex(texlive)
LATEX_PKG=(
	texlive-full
	texlive-xetex
	texlive-lang-english
	texlive-lang-spanish
	texlive-lang-portuguese
	texlive-lang-italian
	texlive-lang-french
	texlive-lang-german
	texlive-lang-polish
	texlive-lang-cyrillic
	texlive-lang-chinese
	texlive-lang-japanese
	texlive-lang-korean
	texlive-lang-arabic
	texlive-lang-indic
	texlive-lang-african
	texlive-lang-other
	texlive-fonts-extra
	texlive-fonts-recommended
	texlive-science
	texlive-pictures
	texlive-music
	texlive-publishers
	texlive-humanities
	texlive-generic-extra
	texlive-generic-recommended
	texlive-bibtex-extra
	texlive-formats-extra
	texlive-games
	texlive-htmlxml
	texlive-luatex
	texlive-metapost
	texlive-omega
	texlive-pstricks
	texlive-xetex
) 

# For fun
FUN_PKG=(
	cmatrix
	sl
	go-music
)


# set all packages as $pkg:
pkg=(
	${BASIC_PKG[@]}
	${LIB_PKG[@]}
	${TOOLS_PKG[@]}
	${MAN_PKG[@]}
	${NET_PKG[@]}
	${GUI_PKG[@]}
	${LATEX_PKG[@]}
	${FUN_PKG[@]}
)
